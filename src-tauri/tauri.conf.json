{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AirSend",
  "version": "0.1.5",
  "identifier": "com.pablodiaz.conexionairplay",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../ui"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../ui"
    },
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AirSend",
        "width": 420,
        "height": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Stream Windows audio to HomePod",
    "longDescription": "Native Windows app that captures system audio via WASAPI and streams it to a HomePod via AirPlay 2.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Pabldi08/AirSend/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwOTlDRDNCNkEzODVCOUMKUldTY1d6aHFPODJaMEdHejROdlNjUGp5UWl1OXo0ZnErWjI3ekRQeEtadVpLVnVqTFEzUEJBemgK"
    }
  }
}
